import java .util.Scanner;
public class Lessthan50check {
    public static void main(String[]args){
        Scanner sc = new Scanner(System.in);
        int num =sc.nextInt();
        if(num<50){
            System.out.println("Less than 50");
        }
        else{
            System.out.println("Greater than or equal to 50");
        }
    }
}
